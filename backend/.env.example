# AutoDocs backend local/dev configuration

# Public dashboard origin that is allowed to use the API with cookies.
DASHBOARD_ORIGIN=http://localhost:5174

# Public backend origin. Set this in production if the backend sits behind a proxy
# or if you want OAuth callbacks to use a canonical host instead of request host.
API_BASE=http://localhost:3002

# Cookie/session signing secret.
SESSION_SECRET=replace-with-a-random-secret

# GitHub OAuth App (user login)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# GitHub App (repo install/connect)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_SLUG=autodocs-gartnertracer

# Paste the PEM contents directly. Literal \n also works.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Optional shared secret for POST /webhook/ingest.
WEBHOOK_SHARED_SECRET=
